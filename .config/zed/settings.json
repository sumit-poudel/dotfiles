{
  "buffer_font_family": "MonoLisa",
  "ui_font_family": "MonoLisa",
  "theme": {
    "mode": "dark",
    "light": "Noctalia Light",
    "dark": "Ashwood",
  },
  "theme_overrides": {
    "Noctalia Dark": {
      "error": "#d07277ff",
      "error.background": "#d072771a",
      "syntax": {
        "comment": {
          "font_style": "italic",
        },
      },
    },
    "Noctalia Light": {
      "syntax": {
        "comment": {
          "font_style": "italic",
        },
      },
    },
  },
  "ui_font_size": 15,
  "buffer_font_size": 15,
  "buffer_line_height": "standard",
  "cursor_shape": "bar",
  "tab_size": 2,
  "auto_indent": "syntax_aware",
  "soft_wrap": "editor_width",
  "extend_comment_on_newline": false,
  "use_smartcase_search": true,
  "selection_highlight": false,
  "multi_cursor_modifier": "cmd_or_ctrl",
  "show_edit_predictions": false,
  "code_lens": "on",
  "vertical_scroll_margin": 2,
  "horizontal_scroll_margin": 2,
  "autoscroll_on_clicks": true,
  "restore_on_startup":"empty_tab",
  "restore_on_file_reopen": false,
  "remove_trailing_whitespace_on_save": true,
  "hover_popover_enabled": false,
  "cli_default_open_behavior": "existing_window",
  "when_closing_with_no_tabs": "keep_window_open",
  "format_on_save": "off",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "scrollbar": {
    "show": "never",
  },
  "gutter": {
    "min_line_number_digits": 0,
  },
  "title_bar": {
    "button_layout": "platform_default",
    "show_onboarding_banner": false,
    "show_branch_name": false,
  },
  "tab_bar": {
    "show": false,
  },
  "tabs": {
    "file_icons": true,
  },
  "toolbar": {
    "code_actions": false,
    "selections_menu": true,
    "quick_actions": false,
    "breadcrumbs": true,
  },
  "status_bar": {
    "active_encoding_button": "enabled",
  },
  "search": {
    "center_on_match": true,
    "regex": true,
  },
  "file_finder": {
    "modal_max_width": "large",
    "file_icons": true,
  },
  "project_panel": {
    "dock": "right",
    "auto_fold_dirs": false,
    "sticky_scroll": false,
    "scrollbar": {
      "show": "never",
    },
  },
  "outline_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "vim_mode": true,
  "relative_line_numbers": "enabled",
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "terminal": {
    "font_family": "MonoLisa",
    "shell": {
      "with_arguments": {
        "program": "/bin/zsh",
        "args": ["-c", "tmux new-session -A -s \"$(basename \"$PWD\")\""],
      },
    },
  },
  "languages": {
    "TypeScript": {
      "show_edit_predictions": true,
    },
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "edit_predictions": {
    "provider": "zed",
    "open_ai_compatible_api": {
      "api_url": "http://localhost:1234/v1/completions",
      "model": "deepseek-r1-distill-qwen-1.5b",
      "prompt_format": "qwen",
      "max_output_tokens": 64,
    },
  },
  "agent": {
    "default_model": {
      "provider": "lmstudio",
      "model": "deepseek-r1-distill-qwen-1.5b",
      "enable_thinking": false,
    },
    "dock": "left",
    "favorite_models": [],
    "model_parameters": [],
  },
  "language_models": {
    "openai": {
      "api_url": "http://127.0.0.1:1234/v1",
      "available_models": [
        {
          "name": "qwen2.5-coder-3b-instruct",
          "max_tokens": 16384,
        },
      ],
    },
  },
  "context_servers": {
    "mcp-server-github": {
      "enabled": true,
      "remote": false,
      "settings": {
        "github_personal_access_token": "",
      },
    },
  },
  "agent_servers": {
    "devin": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry",
    },
  },
}
